# ── Twilio ──────────────────────────────────────────────────────────────
# Get these from console.twilio.com after creating a free account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio sandbox number (keep as-is for sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your own WhatsApp number with country code (e.g. +91 for India)
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Groq ─────────────────────────────────────────────────────────────────
# Free key at console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── NewsAPI (optional but recommended) ──────────────────────────────────
# Free tier: 100 req/day  →  get key at newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ── Polling ──────────────────────────────────────────────────────────────
# How often to check for new articles (minutes).
POLL_INTERVAL_MINUTES=15
