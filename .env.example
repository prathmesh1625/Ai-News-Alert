# ── Twilio ──────────────────────────────────────────────────────────────
# Get these from console.twilio.com after creating a free account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio sandbox number (keep as-is for sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your own WhatsApp number with country code (e.g. +91 for India)
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Groq ─────────────────────────────────────────────────────────────────
# Free key at console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── NewsAPI (optional but recommended) ──────────────────────────────────
# Free tier: 100 req/day  →  get key at newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ── Polling ──────────────────────────────────────────────────────────────
# How often to check for new articles (minutes) when running the always-on loop.
POLL_INTERVAL_MINUTES=15

# How far back each run looks for news (minutes). Keep this comfortably larger
# than the longest real gap between runs — GitHub Actions throttles cron to
# 2-3h — so delayed runs still catch everything. The tracker dedups, so a wide
# window never causes duplicate messages. Default: 6 hours.
LOOKBACK_MINUTES=360

# ── Twilio free-tier budget ────────────────────────────────────────────────
# Max WhatsApp messages per UTC day (protects your free trial credit).
MAX_SENDS_PER_DAY=12
# Max fresh-news items sent in a single run (stops one busy run eating the cap).
MAX_NEWS_PER_RUN=6
# Min hours between "existing tool / tip" fallback messages during quiet spells.
FALLBACK_GAP_HOURS=4
